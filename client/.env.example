# Client configuration
# Copy this file to .env and fill in your values.

# Private key for the wallet that pays for resource access
CLIENT_PRIVATE_KEY=

# URL of the x402-protected resource to request
RESOURCE_URL=http://localhost:3000/joke

# CAIP-2 chain identifier
NETWORK=eip155:31611

# Mezo RPC endpoint
RPC_URL=https://rpc.test.mezo.org

# mUSD token on Mezo testnet
MUSD_ADDRESS=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503

# Canonical Uniswap Permit2 deployment
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3
