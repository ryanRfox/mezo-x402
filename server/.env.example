# Humor server configuration
# Copy this file to .env and fill in your values.

# Payee wallet address (receives payment for resource access)
PAYEE_ADDRESS=

# Server port
HUMOR_PORT=3000

# Facilitator sidecar URL
FACILITATOR_URL=http://localhost:4022

# CAIP-2 chain identifier
NETWORK=eip155:31611

# mUSD token on Mezo testnet
MUSD_ADDRESS=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503

# x402 Permit2 proxy contract address (read by patched @x402/evm)
PROXY_ADDRESS=0x8dea1b08dc2e1D9b556450f736F19968F367A98d
