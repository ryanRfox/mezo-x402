# Facilitator sidecar configuration
# Copy this file to .env and fill in your values.

# Private key for the facilitator wallet (settles payments on-chain)
FACILITATOR_PRIVATE_KEY=

# CAIP-2 chain identifier
NETWORK=eip155:31611

# Mezo RPC endpoint
MEZO_RPC_URL=https://rpc.test.mezo.org

# x402 Permit2 proxy contract address (deployed on Mezo Testnet)
PROXY_ADDRESS=0x8dea1b08dc2e1D9b556450f736F19968F367A98d

# Canonical Uniswap Permit2 deployment
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3

# Facilitator service port
PORT=4022
